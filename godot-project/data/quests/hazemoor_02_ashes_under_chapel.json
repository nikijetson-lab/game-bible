        "3": "roots_grow_cold",
        "4": "reflections_dont_match",
        "5": "manifestation"
      }
    },
    "ritual_prep": {
      "title": "Підготовка до ритуалу",
      "actions": [
        "reconstruct_with_karos",
        "seal_or_transfer_archive",
        "protect_skel",
        "enlist_sella",
        "negotiate_with_rein"
      ]
    },
