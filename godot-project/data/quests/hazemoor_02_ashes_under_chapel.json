      "title": "Тихе відкриття",
      "location": "flooded_chapel",
      "first_choice": [
        "trust_karos",
        "investigate_body",
        "meet_rein"
      ]
    },
    "investigation": {
      "title": "Розслідування",
      "lines": [
        "examine_body",
        "archive_records",
        "question_mirefold",
        "find_skel",
        "read_archive"
      ],
      "archive_requirement": "isra_trust >= 2"
    },
    "doctrinal_reckoning": {
      "title": "Доктринальний розрахунок",
      "disturbance_counter": {
