clue_id = "artifact_empty"
clue_text = "Руфін тримає невеликий камінь із заглибленням всередині. Колись він світився — Варрік бачив, Алтея в Грейфорді підтвердила. Тепер камінь темний, холодний, порожній."
clue_category = "investigation"

