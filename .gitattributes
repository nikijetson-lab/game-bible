# Normalize line endings for cross-platform Windows/WSL work
* text=auto

# Keep source/config/docs as LF in repository
*.gd text eol=lf
*.gdshader text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.uid text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.js text eol=lf
*.css text eol=lf
*.html text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.mp3 binary
*.wav binary
*.ogg binary
*.glb binary
*.gltf binary
*.fbx binary
*.obj binary
*.stl binary
*.blend binary
*.zip binary
*.pdf binary
