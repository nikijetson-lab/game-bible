[node name="Lesson4_NameAtNight" type="Area3D" parent="Lessons"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, -4)
script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_4"
episode_title = "Ім'я вночі"
situation_text = "Міа спить неспокійно — вперше. Ти чуєш слово, яке вона повторює уві сні. Це ім'я. Воно звучить мовою Мурі — чуже, але запам'ятовується. Вранці:"
option_texts = PackedStringArray("Спитати — чиє це ім'я?", "Мовчати, але запам'ятати", "Спитати прямо, коли вона не в настрої говорити")
option_deltas = PackedInt32Array(1, 0, -1)
aftermath_text = "Чиє саме ім'я — лишилось відкритим. Воно може стати важливим пізніше."
prompt = "Момент вибору: Ім'я вночі"

