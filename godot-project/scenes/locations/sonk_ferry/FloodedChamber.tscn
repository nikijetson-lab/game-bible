; === CLUES ===
[node name="PactSealClue" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 12, 2.0, -9)
script = ExtResource("2_clue")
clue_id = "pact_seal"
clue_text = "Оголена стара кам'яна кладка з печатками Пакту. Символи вицвілі, але ще помітні. Цим стінам — століття."
clue_category = "investigation"

[node name="CollisionShape3D" type="CollisionShape3D" parent="PactSealClue"]
