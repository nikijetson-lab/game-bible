transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, -10)
script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_5"
episode_title = "Заборонене місце"
situation_text = "Міа веде тебе в обхід. Вона зупиняється, дивиться в один бік, потім змінює маршрут. Вона навмисно уникає одного місця."
option_texts = PackedStringArray("Спитати, що там", "Спробувати піти туди сам", "Мовчки йти за нею")
option_deltas = PackedInt32Array(1, -1, 0)
aftermath_text = "«Там щось дуже давнє. Не тривожне. Але й не людське. І не наше. Його не треба турбувати.»"
prompt = "Момент вибору: Заборонене місце"

