[node name="MeetingPoint" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.5, 0)
script = ExtResource("2_clue")
clue_id = "salt_meeting"
clue_text = "Приховане місце передачі. Тут сходяться ліки, підроблені печатки й приватні книги. Сьогодні вночі — зустріч."


