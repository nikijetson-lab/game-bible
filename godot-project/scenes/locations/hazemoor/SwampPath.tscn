[node name="Lesson1_NoiseOnWater" type="Area3D" parent="Lessons"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, 14)
script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_1"
episode_title = "Шум на воді"
situation_text = "Міа рухається безшумно. Ти — ні. Болото звучить навколо: хтось реагує на кроки, завмираючи, далі, далі від протоки. Міа зупиняється і дивиться на тебе. Без слів."
option_texts = PackedStringArray("Сповільнитись, ступати м'якше", "Зупинитись і дивитись, як вона ставить ноги", "Продовжити як ішов", "Тривожно озирнутись")
option_deltas = PackedInt32Array(1, 1, 0, -1)
aftermath_text = "Здобич, яку Міа вистежувала, втрачена. Але урок отримано."
prompt = "Момент вибору: Шум на воді"

[node name="CollisionShape3D" type="CollisionShape3D" parent="Lessons/Lesson1_NoiseOnWater"]
shape = SubResource("SphereShape_interact")

[node name="Lesson2_NightSpark" type="Area3D" parent="Lessons"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, 8)
script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_2"
episode_title = "Нічна іскра"
situation_text = "Хтось або щось спостерігає з темряви. Світлячки? Чи не світлячки? У темряві — десятки рухомих жовтих цяток."
option_texts = PackedStringArray("Спитати Міа — що це?", "Підняти зброю, готуючись", "Спостерігати, не рухаючись")
option_deltas = PackedInt32Array(1, -1, 0)
aftermath_text = "«Ти не мусиш боятися всього, що світиться в темряві. Деяке світло просто дивиться — чи варто його боятись.»"
prompt = "Момент вибору: Нічна іскра"

[node name="CollisionShape3D" type="CollisionShape3D" parent="Lessons/Lesson2_NightSpark"]
shape = SubResource("SphereShape_interact")

[node name="Lesson3_DeepWater" type="Area3D" parent="Lessons"]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 0, 0.9, 2)
script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_3"
episode_title = "Глибока вода"
situation_text = "Стариця — широка чорна вода без видимого дна. Міа пірнає і зникає під водою. Довго не з'являється."
option_texts = PackedStringArray("Чекати", "Пірнати, шукати її", "Кричати, гукати її")
option_deltas = PackedInt32Array(1, 0, -1)
aftermath_text = "Болото не завжди небезпечне. Воно просто інше. Страх — поганий порадник. Увага — добрий."
prompt = "Момент вибору: Глибока вода"

