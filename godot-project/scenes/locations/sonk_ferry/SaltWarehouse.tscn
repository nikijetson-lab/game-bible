68|transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, 0.5, -2)
69|script = ExtResource("2_clue")
70|clue_id = "ledger_fragment"
71|clue_text = "Фрагмент книги обліку. Вирвана сторінка. Видно, що ліки проходили через три руки, але останній запис відсутній. Маршрут пов'язаний і з неофіційними каналами, і з офіційним дефіцитом."
