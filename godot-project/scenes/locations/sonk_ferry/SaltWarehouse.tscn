[node name="FakeMedicineCrate" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -4, 0.5, 2)
script = ExtResource("2_clue")
clue_id = "fake_medicine"
clue_text = "Ящик із підробленими печатками Святої Вей. Віск — не того відтінку, нумерація нерівна. Всередині — розведені болотяною водою ліки з фальшивими солями."

[node name="CollisionShape3D" type="CollisionShape3D" parent="FakeMedicineCrate"]
