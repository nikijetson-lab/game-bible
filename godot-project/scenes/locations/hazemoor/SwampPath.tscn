script = ExtResource("3_lesson")
episode_id = "ep1_02_lesson_6"
episode_title = "Чужий слід"
situation_text = "Міа раптом зупиняється над нерухомою водою. Торкає поверхню. Потім швидко повертається: «Тихо. Не рухайся.» Під водою — щось велике. Не активне. Але територіальне."
option_texts = PackedStringArray("Стояти на місці, не дихаючи. Чекати знаку Міа", "Повільно відступати", "Спробувати розгледіти, що там")
option_deltas = PackedInt32Array(1, 0, -1)
