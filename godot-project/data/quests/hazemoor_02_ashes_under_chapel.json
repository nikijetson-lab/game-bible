  "resolutions": {
    "A": {
      "title": "Милосердне стримування",
      "desc": "Ритуал завершено. Тіло забирає вода."
    },
    "B": {
      "title": "Доктринальна чистка",
      "desc": "Рейн викриває все. Архів знищено."
    },
    "V": {
      "title": "Контрольоване викриття",
      "desc": "Архів реформовано. Крихкий баланс."
    },
    "G": {
      "title": "Похована правда",
      "desc": "Тіло знищено. Архів запечатано."
    }
  },
  "variables": [
    "popil_result",
    "popil_arhiv_status",
    "popil_skel_alive",
    "popil_reyin_status"
  ],
  "leads_to": [
    "sonk_ferry_04_quota_knife"
  ],
  "start_location": "flooded_chapel",
  "structure": {
    "acts": [
      {
        "id": "quiet_discovery",
        "title": "Акт 1 — Тихе відкриття",
        "summary": "Тіло в затопленій каплиці. Перевернутий попільний знак. Герой обирає: довіритись Каросу, дослідити тіло, або зустріти Рейна."
      },
      {
        "id": "investigation",
        "title": "Акт 2 — Розслідування",
        "summary": "Герой розслідує тіло, архівні записи, розпитує Мірефолд, знаходить Скела і читає архів (потрібна довіра Ізри ≥2)."
      },
      {
        "id": "doctrinal_reckoning",
        "title": "Акт 3 — Доктринальний розрахунок",
        "summary": "Зростає disturbance: 0=тихо, 3=коріння холоне, 4=відображення не збігаються, 5=маніфестація. Рейн має 3 дні — на 4-й день доктринальний суд."
      },
      {
        "id": "ritual_prep",
        "title": "Акт 4 — Підготовка до ритуалу",
        "summary": "Герой готується: реконструює ритуал з Каросом, вирішує долю архіву, захищає Скела, залучає Селлу, веде переговори з Рейном. Кожна дія — бонус/штраф до фінальної конфронтації."
      },
      {
        "id": "confrontation",
        "title": "Акт 5 — Конфронтація в Затопленій Каплиці",
        "summary": "Ритуал у каплиці. Бонуси знижують складність, disturbance і присутність Рейна — підвищують. Фінальний вибір A/B/V/G."
      }
    ],
    "rein_timer_days": 3,
    "rein_timer_day4": "doctrinal_trial",
    "disturbance_max": 5,
    "phase_order": [
      "quiet_discovery",
      "investigation",
      "doctrinal_reckoning",
      "ritual_prep",
      "confrontation"
    ]
  },
