[node name="LedgerFragment" type="Area3D" parent="."]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3, 0.5, -2)
script = ExtResource("2_clue")
clue_id = "ledger_fragment"
clue_text = "Фрагмент книги обліку. Вирвана сторінка. Видно, що ліки проходили через три руки, але останній запис відсутній. Маршрут пов'язаний і з неофіційними каналами, і з офіційним дефіцитом."

[node name="CollisionShape3D" type="CollisionShape3D" parent="LedgerFragment"]
